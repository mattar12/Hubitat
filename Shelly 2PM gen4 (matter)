// Step 1: Read On/Off (known to work) then Power separately
def testReadSingleAttr() {
    log.info "${device.label ?: device.name}: === TEST: Sequential single-attribute reads ==="

    def epHex = String.format("%02X", getEP1())

    // Read On/Off first (we know this works)
    String cmd1 = matter.readAttributes([[endpointId: epHex, clusterId: "0006", attributeId: "0000"]])
    log.info "${device.label ?: device.name}: TEST sending On/Off read: ${cmd1}"
    sendToDevice(cmd1)

    // Then read power after a delay
    runIn(2, "testReadPowerStep")
}

