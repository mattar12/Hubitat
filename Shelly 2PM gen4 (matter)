// Step 2: Read all attributes from 0x0090 and 0x0091
def diagnoseElectrical() {
    log.info "${device.label ?: device.name}: === ELECTRICAL DIAGNOSTIC ==="
    log.info "${device.label ?: device.name}: Make sure Debug Logging is ON, then check Logs tab"

    def epHex = String.format("%02X", getEP1())

    // Read every attribute 0x0000 through 0x0010 from electrical power cluster
    List<Map<String,String>> attrPaths = []
    for (int attr = 0; attr <= 0x0010; attr++) {
        def attrHex = String.format("%04X", attr)
        attrPaths += [endpointId: epHex, clusterId: "0090", attributeId: attrHex]
    }

    String cmd = matter.readAttributes(attrPaths)
    log.info "${device.label ?: device.name}: Reading ${attrPaths.size()} attrs from cluster 0x0090 EP${getEP1()}"
    log.info "${device.label ?: device.name}: Raw command: ${cmd?.take(400)}"
    sendToDevice(cmd)

    runIn(3, "diagnoseEnergyCluster")
}

def diagnoseEnergyCluster() {
    def epHex = String.format("%02X", getEP1())

    List<Map<String,String>> attrPaths = []
    for (int attr = 0; attr <= 0x0005; attr++) {
        def attrHex = String.format("%04X", attr)
        attrPaths += [endpointId: epHex, clusterId: "0091", attributeId: attrHex]
    }

    String cmd = matter.readAttributes(attrPaths)
    log.info "${device.label ?: device.name}: Reading ${attrPaths.size()} attrs from cluster 0x0091 EP${getEP1()}"
    sendToDevice(cmd)

    runIn(3, "diagnoseEP2Electrical")
}

def diagnoseEP2Electrical() {
    def epHex = String.format("%02X", getEP2())

    List<Map<String,String>> attrPaths = []
    for (int attr = 0; attr <= 0x0010; attr++) {
        def attrHex = String.format("%04X", attr)
        attrPaths += [endpointId: epHex, clusterId: "0090", attributeId: attrHex]
    }

    String cmd = matter.readAttributes(attrPaths)
    log.info "${device.label ?: device.name}: Reading ${attrPaths.size()} attrs from cluster 0x0090 EP${getEP2()}"
