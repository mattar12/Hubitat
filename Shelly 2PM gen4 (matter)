// Step 3: Scan all endpoints 0-10
def scanAllEndpoints() {
    log.info "${device.label ?: device.name}: === SCANNING ENDPOINTS 0-10 ==="

    List<Map<String,String>> attrPaths = []
    for (int ep = 0; ep <= 10; ep++) {
        def epHex = String.format("%02X", ep)
        attrPaths += [endpointId: epHex, clusterId: "0006", attributeId: "0000"]  // On/Off
        attrPaths += [endpointId: epHex, clusterId: "0090", attributeId: "0008"]  // ActivePower
        attrPaths += [endpointId: epHex, clusterId: "0091", attributeId: "0001"]  // Energy
    }

    String cmd = matter.readAttributes(attrPaths)
    log.info "${device.label ?: device.name}: Scanning ${attrPaths.size()} attributes across endpoints 0-10"
    sendToDevice(cmd)
}

// ---------------------------------------------------------------------------
// Switch Commands
// ---------------------------------------------------------------------------
def on() {
    logInfo "Turning on both relays"
    on1()
    on2()
}

def off() {
    logInfo "Turning off both relays"
    off1()
    off2()
}

def on1() {
    logInfo "Turning on relay 1 (endpoint ${getEP1()})"
    sendToDevice(matter.invoke(getEP1(), CLUSTER_ON_OFF, CMD_ON))
    sendEvent(name: "switch1", value: "on")
    updateMainSwitchState()
    updateChildDevice(1, "switch", "on")
}

def off1() {
    logInfo "Turning off relay 1 (endpoint ${getEP1()})"
    sendToDevice(matter.invoke(getEP1(), CLUSTER_ON_OFF, CMD_OFF))
    sendEvent(name: "switch1", value: "off")
    updateMainSwitchState()
    updateChildDevice(1, "switch", "off")
}

def on2() {
    logInfo "Turning on relay 2 (endpoint ${getEP2()})"
    sendToDevice(matter.invoke(getEP2(), CLUSTER_ON_OFF, CMD_ON))
    sendEvent(name: "switch2", value: "on")
    updateMainSwitchState()
    updateChildDevice(2, "switch", "on")
}

def off2() {
    logInfo "Turning off relay 2 (endpoint ${getEP2()})"
    sendToDevice(matter.invoke(getEP2(), CLUSTER_ON_OFF, CMD_OFF))
    sendEvent(name: "switch2", value: "off")
    updateMainSwitchState()
    updateChildDevice(2, "switch", "off")
}

def toggle1() {
    logInfo "Toggling relay 1 (endpoint ${getEP1()})"
    sendToDevice(matter.invoke(getEP1(), CLUSTER_ON_OFF, CMD_TOGGLE))
    runIn(1, "refresh")
}

def toggle2() {
    logInfo "Toggling relay 2 (endpoint ${getEP2()})"
    sendToDevice(matter.invoke(getEP2(), CLUSTER_ON_OFF, CMD_TOGGLE))
    runIn(1, "refresh")
}

private updateMainSwitchState() {
    def s1 = device.currentValue("switch1") ?: "off"
    def s2 = device.currentValue("switch2") ?: "off"
    sendEvent(name: "switch", value: (s1 == "on" || s2 == "on") ? "on" : "off")
}

