    def epHex = String.format("%02X", getEP1())
    String cmd = matter.readAttributes([[endpointId: epHex, clusterId: "0090", attributeId: "0008"]])
    log.info "${device.label ?: device.name}: TEST sending ActivePower read: ${cmd}"
    sendToDevice(cmd)

    runIn(2, "testReadVoltageStep")
}

