// ---------------------------------------------------------------------------
// Power Factor Calculation
// ---------------------------------------------------------------------------
def calculateAllPowerFactors() {
    logInfo "=== CALCULATING POWER FACTORS ==="
    calculatePowerFactorForEndpoint(1)
    calculatePowerFactorForEndpoint(2)

    logInfo "Voltage: ${device.currentValue('voltage') ?: 0}V"
    logInfo "Relay 1: I=${device.currentValue('current1') ?: 0}A, P=${device.currentValue('power1') ?: 0}W, " +
            "S=${device.currentValue('apparentPower1') ?: 0}VA, PF=${device.currentValue('powerFactor1') ?: 1.0}"
    logInfo "Relay 2: I=${device.currentValue('current2') ?: 0}A, P=${device.currentValue('power2') ?: 0}W, " +
            "S=${device.currentValue('apparentPower2') ?: 0}VA, PF=${device.currentValue('powerFactor2') ?: 1.0}"
    logInfo "Overall Power Factor: ${device.currentValue('powerFactor') ?: 1.0}"
}

private calculatePowerFactorForEndpoint(int relayNum) {
    def voltage = device.currentValue("voltage") ?: 0
    def current = device.currentValue("current${relayNum}") ?: 0
    def activePower = device.currentValue("power${relayNum}") ?: 0

    if (voltage > 0 && current > 0.001 && activePower > 0.1) {
        def apparentPower = Math.round((voltage * current) * 10) / 10.0
        def powerFactor = Math.min(1.0, Math.max(0.0, activePower / apparentPower))
        powerFactor = Math.round(powerFactor * 1000) / 1000.0

        sendEvent(name: "apparentPower${relayNum}", value: apparentPower, unit: "VA")
        sendEvent(name: "powerFactor${relayNum}", value: powerFactor)
        updateChildDevice(relayNum, "apparentPower", apparentPower)
        updateChildDevice(relayNum, "powerFactor", powerFactor)

        def ap1 = relayNum == 1 ? apparentPower : (device.currentValue("apparentPower1") ?: 0)
        def ap2 = relayNum == 2 ? apparentPower : (device.currentValue("apparentPower2") ?: 0)
        def totalAP = ap1 + ap2
        sendEvent(name: "apparentPower", value: totalAP, unit: "VA")

        def p1 = device.currentValue("power1") ?: 0
        def p2 = device.currentValue("power2") ?: 0
        def totalP = p1 + p2
        def overallPF = totalAP > 0 ? Math.min(1.0, Math.round((totalP / totalAP) * 1000) / 1000.0) : 1.0
        sendEvent(name: "powerFactor", value: overallPF)
    }
}

// ---------------------------------------------------------------------------
// Matter Message Parsing
//
// This version logs EVERYTHING at info level when debug is on
// to help identify what the device is actually sending back.
// ---------------------------------------------------------------------------
def parse(String description) {
    // ALWAYS log raw incoming messages when debug is enabled
    if (logEnable) log.info "${device.label ?: device.name}: PARSE RAW: ${description}"

    if (!description) {
        if (logEnable) log.info "${device.label ?: device.name}: PARSE: empty description received"
        return
    }

    try {
        def descMap = matter.parseDescriptionAsMap(description)

        if (logEnable) log.info "${device.label ?: device.name}: PARSE MAP: ${descMap}"

        if (descMap) {
            // Handle both single map and list of maps
            if (descMap instanceof List) {
                descMap.each { item ->
                    if (item instanceof Map) {
                        processMatterMessage(item)
                    }
                }
            } else if (descMap instanceof Map) {
                processMatterMessage(descMap)
            } else {
                log.warn "${device.label ?: device.name}: PARSE: Unexpected response type: ${descMap}"
            }
        }
    } catch (Exception e) {
        log.warn "${device.label ?: device.name}: PARSE ERROR: ${e.message}"
        log.warn "${device.label ?: device.name}: PARSE ERROR description: ${description?.take(300)}"
    }
}

private void processMatterMessage(Map descMap) {
    if (logEnable) log.info "${device.label ?: device.name}: PROCESSING: ${descMap}"

    if (!descMap?.cluster) {
        if (logEnable) log.info "${device.label ?: device.name}: SKIP: no cluster field, keys=${descMap?.keySet()}"
        return
    }

    def endpoint = 0
    def cluster = 0
    def attrId = -1

    try {
        if (descMap.endpoint) endpoint = Integer.parseInt(descMap.endpoint, 16)
        cluster = Integer.parseInt(descMap.cluster, 16)
        if (descMap.attrId) attrId = Integer.parseInt(descMap.attrId, 16)
    } catch (Exception e) {
        log.warn "${device.label ?: device.name}: ID parse error: ${e.message}, descMap=${descMap}"
        return
    }

    def relayNum = relayNumberForEndpoint(endpoint)

    if (logEnable) log.info "${device.label ?: device.name}: DECODED: ep=${endpoint}(relay${relayNum}), " +
        "cluster=0x${String.format('%04X', cluster)}, attr=0x${attrId >= 0 ? String.format('%04X', attrId) : 'none'}, " +
        "value=${descMap.value}"

    switch (cluster) {
        case CLUSTER_ON_OFF:
            processOnOff(descMap, endpoint, attrId, relayNum)
            break
        case CLUSTER_ELECTRICAL_POWER_MEAS:
            processElectricalPower(descMap, endpoint, attrId, relayNum)
            break
        case CLUSTER_ELECTRICAL_ENERGY_MEAS:
            processElectricalEnergy(descMap, endpoint, attrId, relayNum)
            break
        default:
            // Log ALL unhandled clusters so we can discover what the device reports
            log.info "${device.label ?: device.name}: OTHER CLUSTER: " +
                "0x${String.format('%04X', cluster)}, ep=${endpoint}, " +
                "attr=0x${attrId >= 0 ? String.format('%04X', attrId) : 'none'}, " +
                "value=${descMap.value}"
            break
    }

    sendEvent(name: "healthStatus", value: "online")
}

// ---------------------------------------------------------------------------
// On/Off Processing
// ---------------------------------------------------------------------------
private void processOnOff(Map descMap, int endpoint, int attrId, int relayNum) {
    if (attrId != ATTR_ON_OFF || !descMap.value) return

    def switchState = descMap.value == "01" ? "on" : "off"

    if (relayNum == 1 || relayNum == 2) {
        sendEvent(name: "switch${relayNum}", value: switchState)
        updateMainSwitchState()
        updateChildDevice(relayNum, "switch", switchState)
        if (txtEnable) logInfo "Relay ${relayNum} is ${switchState}"
    } else {
        log.info "${device.label ?: device.name}: On/Off from unexpected endpoint ${endpoint}: ${switchState}"
    }
}

// ---------------------------------------------------------------------------
// Electrical Power Measurement Processing (Cluster 0x0090)
// ---------------------------------------------------------------------------
private void processElectricalPower(Map descMap, int endpoint, int attrId, int relayNum) {
    if (!descMap.value) {
        log.info "${device.label ?: device.name}: Power cluster - no value, attr=0x${String.format('%04X', attrId)}"
        return
    }

    // ALWAYS log electrical data
    log.info "${device.label ?: device.name}: ELECTRICAL: ep=${endpoint}(relay${relayNum}), " +
        "attr=0x${String.format('%04X', attrId)}, rawHex=${descMap.value}"

    try {
        def rawValue = Long.parseLong(descMap.value, 16)
        log.info "${device.label ?: device.name}: ELECTRICAL DECODED: attr=0x${String.format('%04X', attrId)}, " +
            "decimal=${rawValue}"

        switch (attrId) {
            case ATTR_ACTIVE_POWER:   // 0x0008
            case ATTR_RMS_POWER:      // 0x000D
                processPowerValue(rawValue, relayNum, attrId)
                break

            case ATTR_VOLTAGE:        // 0x0004
            case ATTR_RMS_VOLTAGE:    // 0x000B
                processVoltageValue(rawValue, attrId)
                break

            case ATTR_ACTIVE_CURRENT: // 0x0005
            case ATTR_RMS_CURRENT:    // 0x000C
            case ATTR_APPARENT_CURRENT: // 0x0007
                processCurrentValue(rawValue, relayNum, attrId)
                break

            case ATTR_POWER_FACTOR:   // 0x000F
                def pf = rawValue / 100.0
                if (pf >= 0 && pf <= 1.0) {
                    sendEvent(name: "powerFactor${relayNum}", value: pf)
                    log.info "${device.label ?: device.name}: Relay ${relayNum} power factor: ${pf}"
                }
                break

            default:
                log.info "${device.label ?: device.name}: UNKNOWN electrical attr " +
                    "0x${String.format('%04X', attrId)} = ${rawValue} (hex: ${descMap.value})"
                break
        }
    } catch (Exception e) {
        log.warn "${device.label ?: device.name}: Error processing electrical: ${e.message}, value=${descMap.value}"
    }
}

private void processPowerValue(long rawValue, int relayNum, int attrId) {
    // Auto-detect scaling
    def power = 0.0
    if (rawValue > 100000) {
        power = rawValue / 1000.0  // milliwatts to watts
    } else if (rawValue > 10000) {
        power = rawValue / 100.0   // centiwatts to watts
    } else if (rawValue > 1000) {
        power = rawValue / 10.0    // deciwatts to watts
    } else {
        power = rawValue as double // already watts
    }
    power = Math.round(power * 10) / 10.0

    log.info "${device.label ?: device.name}: POWER: relay${relayNum} raw=${rawValue}, " +
        "calculated=${power}W (attr=0x${String.format('%04X', attrId)})"

    if (relayNum >= 1 && relayNum <= 2) {
        sendEvent(name: "power${relayNum}", value: power, unit: "W")
        updateChildDevice(relayNum, "power", power)

        def p1 = relayNum == 1 ? power : (device.currentValue("power1") ?: 0)
        def p2 = relayNum == 2 ? power : (device.currentValue("power2") ?: 0)
        sendEvent(name: "power", value: Math.round((p1 + p2) * 10) / 10.0, unit: "W")

        calculatePowerFactorForEndpoint(relayNum)
    }
}

private void processVoltageValue(long rawValue, int attrId) {
    def voltage = 0.0
    if (rawValue > 100000) {
        voltage = rawValue / 1000.0  // millivolts
    } else if (rawValue > 10000) {
        voltage = rawValue / 100.0   // centivolts
    } else if (rawValue > 1000) {
        voltage = rawValue / 10.0    // decivolts
    } else {
        voltage = rawValue as double // volts
    }
    voltage = Math.round(voltage * 10) / 10.0

    log.info "${device.label ?: device.name}: VOLTAGE: raw=${rawValue}, " +
        "calculated=${voltage}V (attr=0x${String.format('%04X', attrId)})"

    sendEvent(name: "voltage", value: voltage, unit: "V")
}

private void processCurrentValue(long rawValue, int relayNum, int attrId) {
    def current = rawValue / 1000.0  // default: milliamps to amps
    current = Math.round(current * 1000) / 1000.0

    log.info "${device.label ?: device.name}: CURRENT: relay${relayNum} raw=${rawValue}, " +
        "calculated=${current}A (attr=0x${String.format('%04X', attrId)})"

    if (relayNum >= 1 && relayNum <= 2) {
        sendEvent(name: "current${relayNum}", value: current, unit: "A")
        updateChildDevice(relayNum, "current", current)

        def c1 = relayNum == 1 ? current : (device.currentValue("current1") ?: 0)
        def c2 = relayNum == 2 ? current : (device.currentValue("current2") ?: 0)
        sendEvent(name: "current", value: Math.round((c1 + c2) * 1000) / 1000.0, unit: "A")

        calculatePowerFactorForEndpoint(relayNum)
    }
}

// ---------------------------------------------------------------------------
// Electrical Energy Measurement Processing (Cluster 0x0091)
// ---------------------------------------------------------------------------
private void processElectricalEnergy(Map descMap, int endpoint, int attrId, int relayNum) {
    if (!descMap.value) return

    log.info "${device.label ?: device.name}: ENERGY: ep=${endpoint}(relay${relayNum}), " +
        "attr=0x${String.format('%04X', attrId)}, rawHex=${descMap.value}"

    try {
        def rawValue = Long.parseLong(descMap.value, 16)
        log.info "${device.label ?: device.name}: ENERGY DECODED: decimal=${rawValue}"

        // Auto-detect scaling
        def energy = 0.0
        if (rawValue > 1000000) {
            energy = rawValue / 1000000.0  // milliwatt-hours to kWh
        } else if (rawValue > 1000) {
            energy = rawValue / 1000.0     // watt-hours to kWh
        } else {
            energy = rawValue as double    // already kWh
        }
        energy = Math.round(energy * 1000000) / 1000000.0

        log.info "${device.label ?: device.name}: ENERGY: relay${relayNum} raw=${rawValue}, calculated=${energy} kWh"

        if (relayNum >= 1 && relayNum <= 2) {
            sendEvent(name: "energy${relayNum}", value: energy, unit: "kWh")
            updateChildDevice(relayNum, "energy", energy)

            def e1 = relayNum == 1 ? energy : (device.currentValue("energy1") ?: 0)
            def e2 = relayNum == 2 ? energy : (device.currentValue("energy2") ?: 0)
            sendEvent(name: "energy", value: Math.round((e1 + e2) * 1000000) / 1000000.0, unit: "kWh")
        }
    } catch (Exception e) {
        log.warn "${device.label ?: device.name}: Error processing energy: ${e.message}"
    }
}

// ---------------------------------------------------------------------------
// Child Device Management
// ---------------------------------------------------------------------------
private void createChildDevicesPair() {
    if (!createChildDevices) return

    for (int i = 1; i <= 2; i++) {
        def childDni = "${device.deviceNetworkId}-${i}"
        def child = getChildDevice(childDni)

        if (!child) {
            logInfo "Creating child device for Relay ${i}"
            try {
                child = addChildDevice("hubitat", "Generic Component Switch", childDni, [
                    name: "Shelly 2PM Gen4 - Relay ${i}",
                    label: "${device.label ?: device.name} - Relay ${i}",
                    isComponent: true
                ])

                child.sendEvent(name: "switch", value: device.currentValue("switch${i}") ?: "off", isStateChange: true)
                def power = device.currentValue("power${i}") ?: 0
                if (power > 0) child.sendEvent(name: "power", value: power, unit: "W")
                def current = device.currentValue("current${i}") ?: 0
                if (current > 0) child.sendEvent(name: "current", value: current, unit: "A")
                def energy = device.currentValue("energy${i}") ?: 0
                if (energy > 0) child.sendEvent(name: "energy", value: energy, unit: "kWh")

                logInfo "Child device for Relay ${i} created and initialized"
            } catch (Exception e) {
                log.warn "${device.label ?: device.name}: Error creating child device: ${e.message}"
            }
        }
    }
}

private void removeChildDevices() {
    getChildDevices().each { child ->
        try {
            logInfo "Removing child device: ${child.label}"
            deleteChildDevice(child.deviceNetworkId)
        } catch (Exception e) {
            log.warn "${device.label ?: device.name}: Error removing child device: ${e.message}"
        }
    }
}

private void updateChildDevice(int relayNum, String attribute, value) {
    if (!createChildDevices) return

    def childDni = "${device.deviceNetworkId}-${relayNum}"
    def child = getChildDevice(childDni)

    if (child) {
        try {
            state["child${relayNum}_${attribute}"] = value
            child.sendEvent(name: attribute, value: value, isStateChange: true, displayed: true)

            if (attribute == "switch") {
                child.sendEvent(name: "switch", value: value, isStateChange: true, displayed: true,
                    descriptionText: "Relay ${relayNum} is ${value}")
            }

            if (logEnable) log.debug "${device.label ?: device.name}: Updated child ${relayNum}: ${attribute} = ${value}"
        } catch (Exception e) {
            if (logEnable) log.debug "${device.label ?: device.name}: Error updating child ${relayNum}: ${e.message}"
        }
    }
}

def maintainChildStates() {
    if (!createChildDevices) return

    for (int i = 1; i <= 2; i++) {
        def childDni = "${device.deviceNetworkId}-${i}"
        def child = getChildDevice(childDni)
        if (!child) continue

        def switchState = device.currentValue("switch${i}") ?: "off"
        def power = device.currentValue("power${i}") ?: 0
        def current = device.currentValue("current${i}") ?: 0
        def energy = device.currentValue("energy${i}") ?: 0

        def childSwitch = child.currentValue("switch")
        if (!childSwitch || childSwitch != switchState) {
            child.sendEvent(name: "switch", value: switchState, isStateChange: true, displayed: true)
        }

        if (power > 0) {
            def childPower = child.currentValue("power")
            if (!childPower || Math.abs(childPower - power) > 0.1) {
                child.sendEvent(name: "power", value: power, unit: "W", isStateChange: true)
            }
        }

        if (current > 0) {
            def childCurrent = child.currentValue("current")
            if (!childCurrent || Math.abs(childCurrent - current) > 0.001) {
                child.sendEvent(name: "current", value: current, unit: "A", isStateChange: true)
            }
        }

        if (energy > 0) {
            def childEnergy = child.currentValue("energy")
            if (!childEnergy || Math.abs(childEnergy - energy) > 0.000001) {
                child.sendEvent(name: "energy", value: energy, unit: "kWh", isStateChange: true)
            }
        }
    }

    if (logEnable) log.debug "${device.label ?: device.name}: Child state maintenance complete"
}

def syncChildDevices() {
    logInfo "Syncing child devices with parent state..."

    if (!createChildDevices) {
        logInfo "Child devices disabled"
        return
    }

    for (int i = 1; i <= 2; i++) {
        def childDni = "${device.deviceNetworkId}-${i}"
        def child = getChildDevice(childDni)

        if (child) {
            def switchState = device.currentValue("switch${i}") ?: "off"
            def power = device.currentValue("power${i}") ?: 0
            def current = device.currentValue("current${i}") ?: 0
            def energy = device.currentValue("energy${i}") ?: 0

            child.sendEvent(name: "switch", value: switchState, isStateChange: true, displayed: true)
            if (power > 0) child.sendEvent(name: "power", value: power, unit: "W", isStateChange: true)
            if (current > 0) child.sendEvent(name: "current", value: current, unit: "A", isStateChange: true)
            if (energy > 0) child.sendEvent(name: "energy", value: energy, unit: "kWh", isStateChange: true)

            logInfo "Child ${i} synced: switch=${switchState}, power=${power}W"
        } else {
            logInfo "Child device ${i} not found"
        }
    }

    logInfo "Child device sync complete"
}

// ---------------------------------------------------------------------------
// Child Device Command Handlers
// ---------------------------------------------------------------------------
void componentOn(cd) {
    if (!cd) return
    def relayNum = cd.deviceNetworkId.split("-")[-1] as Integer
    logInfo "Child device command: turn on relay ${relayNum}"
    if (relayNum == 1) on1()
    else if (relayNum == 2) on2()
    runIn(1, "maintainChildStates")
}

void componentOff(cd) {
    if (!cd) return
    def relayNum = cd.deviceNetworkId.split("-")[-1] as Integer
    logInfo "Child device command: turn off relay ${relayNum}"
    if (relayNum == 1) off1()
    else if (relayNum == 2) off2()
    runIn(1, "maintainChildStates")
}

void componentRefresh(cd) {
    refresh()
    runIn(2, "maintainChildStates")
}

// ---------------------------------------------------------------------------
// Matter Communication Helper
// ---------------------------------------------------------------------------
private void sendToDevice(String cmd) {
    if (cmd) {
        sendHubCommand(new hubitat.device.HubAction(cmd, hubitat.device.Protocol.MATTER))
    } else {
        log.warn "${device.label ?: device.name}: sendToDevice called with null command!"
    }
}

// ---------------------------------------------------------------------------
// Logging
// ---------------------------------------------------------------------------
private logInfo(msg) {
    if (txtEnable) log.info "${device.label ?: device.name}: ${msg}"
}

def logsOff() {
    log.info "${device.label ?: device.name}: Debug logging disabled"
    device.updateSetting("logEnable", [value: "false", type: "bool"])
}
